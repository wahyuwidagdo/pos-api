# Server Configuration
PORT=3000
JWT_SECRET=your_super_secret_jwt_key_here
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Database Configuration
# Gunakan "localhost" jika menjalankan aplikasi secara lokal dengan "go run"
# Gunakan "db" jika menjalankan seluruh aplikasi via docker-compose
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_postgres_username
DB_PASSWORD=your_postgres_password
DB_NAME=pos
DB_SSL_MODE=disable
